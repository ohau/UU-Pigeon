# ==========================================
# 1. 操作系統垃圾檔案 (OS general)
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ==========================================
# 2. 編輯器與 IDE 設定檔 (Editors)
# ==========================================
# VS Code 個人設定（每台電腦的視窗大小、解譯器路徑都不同，不該上傳）
.vscode/
!.vscode/extensions.json
.history/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ==========================================
# 3. 後端 / Python 相關快取與環境 (Backend / Python)
# ==========================================
.venv/
venv/
ENV/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
htmlcov/
.pytest_cache/
.tox/

# ==========================================
# 4. iOS / Apple 開發相關 (iOS / Swift / Xcode)
# ==========================================
# Xcode 個人設定與編譯暫存（極度重要，否則兩個人會天天衝突）
build/
DerivedData/
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
*.xcuserdata/
*.xcworkspace/*
!*.xcworkspace/contents.xcworkspace
Pods/
.xcworkspace/xcuserdata/

# ==========================================
# 5. 敏感資料與環境變數 (Secrets / Environments)
# ==========================================
# 絕對不能上傳的密碼、API Key 金鑰檔
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key